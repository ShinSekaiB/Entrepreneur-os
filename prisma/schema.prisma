generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStage {
  IDEA
  VALIDATION
  PREPARATION
  LAUNCH
  GROWTH
  ACTIVE
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum AnalysisType {
  BUSINESS
  MARKETING
  FINANCIAL
  GENERAL
  REALISATION
  FINAL
}

model RealisationData {
  id        String   @id @default(cuid())
  projectId String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("realisation_data")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
  EXPERT
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  language      String   @default("fr")
  experience    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts   Account[]
  sessions   Session[]
  ownedWorkspaces Workspace[]  @relation("WorkspaceOwner")
  workspaces WorkspaceMember[]
  feedbacks  Feedback[]
  subscriptions Subscription[]
  aiCostLogs AICostLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String   @default("Mon espace")
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  projects Project[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole @default(MEMBER)
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  description String?
  sector      String?
  location    String?
  stage       ProjectStage  @default(IDEA)
  score       Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessData   BusinessData?
  marketingData  MarketingData?
  realisationData RealisationData?
  projectMemory  ProjectMemory?
  progress       ProjectProgress?
  analyses       Analysis[]
  recommendations Recommendation[]
  tasks          Task[]
  conversations  Conversation[]
  decisions      Decision[]
  milestones     Milestone[]

  @@map("projects")
}

model BusinessData {
  id               String   @id @default(cuid())
  projectId        String   @unique
  problem          String?
  solution         String?
  targetCustomer   String?
  valueProposition String?
  businessModel    String?
  revenueSources   String?
  costs            Json?
  competitors      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("business_data")
}

model MarketingData {
  id            String   @id @default(cuid())
  projectId     String   @unique
  positioning   String?
  audience      Json?
  persona       Json?
  brandTone     String?
  channels      Json?
  strategy      Json?
  contentPlan   Json?
  marketingScore Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("marketing_data")
}

model Analysis {
  id        String       @id @default(cuid())
  projectId String
  type      AnalysisType
  content   Json
  score     Int?
  createdAt DateTime     @default(now())

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@map("analyses")
}

model Recommendation {
  id          String   @id @default(cuid())
  analysisId  String
  projectId   String
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  category    String?
  createdAt   DateTime @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks    Task[]

  @@map("recommendations")
}

model Task {
  id              String     @id @default(cuid())
  projectId       String
  recommendationId String?
  title           String
  description     String?
  priority        Priority   @default(MEDIUM)
  status          TaskStatus @default(TODO)
  dueDate         DateTime?
  createdAt       DateTime   @default(now())
  completedAt     DateTime?

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recommendation Recommendation? @relation(fields: [recommendationId], references: [id])

  @@map("tasks")
}

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("conversations")
}

model ProjectMemory {
  id        String   @id @default(cuid())
  projectId String   @unique
  facts     Json?
  summary   String?
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_memories")
}

model ProjectProgress {
  id             String   @id @default(cuid())
  projectId      String   @unique
  maturityLevel  Int      @default(0)
  completionRate Int      @default(0)
  completedGoals Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_progress")
}

model Milestone {
  id          String        @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus    @default(TODO)
  proof       String?
  completedAt DateTime?
  createdAt   DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Decision {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  impact      String?
  result      String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("decisions")
}

model AICostLog {
  id               String   @id @default(cuid())
  userId           String
  projectId        String?
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  cost             Float
  duration         Int
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_cost_logs")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  content   String
  rating    Int?
  category  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

model Subscription {
  id            String           @id @default(cuid())
  userId        String           @unique
  plan          SubscriptionPlan @default(FREE)
  stripeId      String?
  currentPeriod DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
